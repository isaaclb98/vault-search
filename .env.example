# Copy to .env and fill in. .env is gitignored.
# Real process env always wins over .env values, so CI / containers can override.

# --- Vault ---
# Absolute path to the Obsidian vault root. Default: ~/projects/obsidian.
# VAULT_PATH=~/projects/obsidian

# --- Qdrant ---
# QDRANT_URL=https://qdrant.example.com
# QDRANT_API_KEY=your_key_here
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=vault-fragments
# QDRANT_API_KEY=

# --- Ollama ---
# Local Ollama host. Models are pulled separately via `ollama pull`.
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Canvas storage ---
# Directory for saved canvas JSON files. Default: ./canvases
# (relative to the repo root).
# CANVAS_DIR=./canvases

# --- Tuning (optional) ---
# EMBED_DIM=768
# TOP_K=8
# MAX_TOOL_CALLS=6
# LOG_LEVEL=INFO